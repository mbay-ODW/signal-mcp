# Signal MCP — Klartext-Secrets (nie committen!)

# Basis-Domain (Host wird signal-mcp.<DOMAIN>, Authelia authelia.<DOMAIN>)
DOMAIN=bay-ram.de

# Deine Signal-Nummer (die als Zweitgerät gelinkt wird), E.164 mit +
SIGNAL_NUMBER=+491701234567

# Statischer Bearer Token für Claude Desktop / direkte API-Clients
MCP_API_KEY=dein_geheimer_api_key

# Authelia OIDC Client Secret (Plaintext; der bcrypt-Hash steht in Authelia)
OIDC_CLIENT_SECRET=dein_oidc_client_secret_klartext
