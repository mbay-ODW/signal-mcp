# Signal MCP — Klartext-Secrets (nie committen!)

# Deine Signal-Nummer (die als Zweitgerät gelinkt wird), E.164 mit +
SIGNAL_NUMBER=+491701234567

# Statischer Bearer Token für Claude Desktop / direkte API-Clients
MCP_API_KEY=dein_geheimer_api_key

# Authelia OIDC Introspection (für den claude.ai-Connector)
OIDC_INTROSPECTION_URL=https://signal-mcp.bay-ram.de/api/oidc/introspection
OIDC_CLIENT_ID=signal-mcp
OIDC_CLIENT_SECRET=dein_oidc_client_secret_klartext

# Optional: Issuer + öffentliche Server-URL für die OAuth-Discovery-Fallbacks
OAUTH_ISSUER=https://authelia.bay-ram.de
MCP_SERVER_URL=https://signal-mcp.bay-ram.de
